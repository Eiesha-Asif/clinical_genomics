Bootstrap: docker
From: ubuntu:22.04

%post
    # 1. Essential system tools install 
    apt-get update && apt-get install -y \
        wget \
        curl \
        bzip2 \
        ca-certificates \
        git \
        samtools \
        python3 \
        pip
    
    # 2. Miniconda install 
    wget https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh -O miniconda.sh
    bash miniconda.sh -b -p /opt/conda
    rm miniconda.sh
    export PATH=/opt/conda/bin:$PATH

    # Channels set for bioinformatics tools
    conda config --add channels defaults
    conda config --add channels bioconda
    conda config --add channels conda-forge
    conda config --set channel_priority strict

    # 3.Clair3 installation through conda
    conda install -y clair3

    # Clean up for container size
    apt-get clean && rm -rf /var/lib/apt/lists/*
    conda clean -a -y

%environment
    # paths active during container running
    export PATH=/opt/conda/bin:$PATH
    export LC_ALL=C

%runscript
    echo "=========================================================="
    echo " Welcome to Clinical Genomics Container (Clair3 Only)"
    echo "=========================================================="
    echo "Checking installed tools versions:"
    echo -n "Clair3: " && run_clair3.sh --version 2>&1 | head -n 1
    echo -n "Samtools: " && samtools --version | head -n 1
    echo "=========================================================="

%labels
    Maintainer Eiesha Asif
    Version v3.0
    Description Variant Calling Pipeline Container with Clair3